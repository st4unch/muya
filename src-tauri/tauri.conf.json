{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apex Mission Control",
  "version": "0.1.2",
  "identifier": "com.staunch.apex-mission-control",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Apex Mission Control",
        "width": 1440,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["txt", "md", "json", "yaml", "yml", "toml", "ts", "tsx", "js", "jsx", "rs", "py", "sh", "css", "html", "xml", "csv", "log", "env"],
        "name": "Text File",
        "role": "Editor"
      }
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Murat Aydoan (7PG95YYJ64)"
    }
  }
}
